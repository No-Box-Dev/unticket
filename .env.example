# === GitHub App user-OAuth (optional — enables "Sign in with GitHub" button) ===
# Without these, the app falls back to personal access token login.

# GitHub App OAuth Client ID (public, safe for frontend)
VITE_GITHUB_APP_CLIENT_ID=

# OAuth proxy URL (for GitHub Pages / static deploys)
# Deploy the worker in /worker/ to Cloudflare Workers and set the URL here.
# For Pages deploys, leave blank — it uses /api/auth/callback instead.
VITE_OAUTH_PROXY_URL=

# GitHub App OAuth Client Secret (server-side only — never in frontend)
# Set this in Cloudflare Pages secrets, NOT here.
# GITHUB_APP_CLIENT_SECRET=

# === Dev mode (localhost only) ===
# Skip OAuth and auto-login with a GitHub PAT
# VITE_DEV_TOKEN=ghp_your_personal_access_token
# VITE_DEV_ORG=Your-Org-Name
