# ============================================================================
# Unticket environment configuration
# ----------------------------------------------------------------------------
# Copy to .env.local for local dev. Server-side secrets (the non-VITE_ ones)
# are NEVER read from this file in production — set them as Cloudflare Pages
# secrets via `wrangler pages secret put <NAME>`. See DEPLOY.md.
# ============================================================================

# === Frontend (Vite, build-time, PUBLIC — safe to ship in the bundle) ===

# GitHub App OAuth Client ID. Without it, the app falls back to PAT login.
VITE_GITHUB_APP_CLIENT_ID=

# OAuth proxy URL — only for static deploys (e.g. GitHub Pages) that can't run
# the /api/auth/callback function. For Cloudflare Pages, leave blank.
VITE_OAUTH_PROXY_URL=

# Dev-server API proxy target. Where `npm run dev` forwards /api/* calls.
# Point this at your own deployed instance, or run functions locally.
VITE_API_TARGET=https://app.unticket.ai

# === Dev mode only (localhost) — skip OAuth and auto-login with a PAT ===
# VITE_DEV_TOKEN=ghp_your_personal_access_token
# VITE_DEV_ORG=Your-Org-Name

# ============================================================================
# === Server-side secrets — set via `wrangler pages secret put`, NOT here ===
# ============================================================================
# Listed for reference. Required for OAuth + webhooks + narration to work.
#
#   GITHUB_APP_ID              GitHub App ID (numeric), for signing App JWTs
#   GITHUB_APP_CLIENT_ID       GitHub App OAuth client id (server copy)
#   GITHUB_APP_CLIENT_SECRET   GitHub App OAuth client secret
#   GITHUB_APP_PRIVATE_KEY     GitHub App private key (PEM)
#   GITHUB_WEBHOOK_SECRET      HMAC secret matching the org webhook config
#   ENCRYPTION_KEY             64-char hex key; encrypts stored refresh tokens
#                              and BYOK LLM keys at rest
#   ZHIPU_API_KEY              Default LLM provider key (orgs can override BYOK)
#
# For local dev with functions, put these in .dev.vars (gitignored).
#
# === Cloudflare bindings (configured in wrangler.toml, not as env vars) ===
#   DB              D1 database
#   TASK_QUEUE      Queue producer (unticket-tasks)
#   EVENTS_ARCHIVE  R2 bucket (unticket-events-archive)
