# Missing asset chunks must 404, never fall back to index.html.
# Pages applies SPA routing by default and serves index.html with 200 for
# any unknown path — including /assets/*.js requests racing a deploy. That
# HTML response inherits the immutable cache-control header from _headers
# and gets pinned at the edge for a year, poisoning fresh browsers.
/assets/*  404

# SPA fallback for everything else.
/*  /index.html  200
